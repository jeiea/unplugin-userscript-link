{
  "name": "@jeiea/unplugin-userscript-link",
  "version": "0.2.0",
  "exports": {
    ".": "./src/unplugin.ts",
    "./rolldown": "./src/rolldown.ts"
  },
  "tasks": {
    "hooks:install": "deno run --allow-read=deno.json,.git/hooks/ --allow-write=.git/hooks/ jsr:@hongminhee/deno-task-hooks",
    "hooks:pre-commit": "deno run -A npm:lint-staged@^17.0.5 --hide-unstaged --config lint-staged.config.ts",
    "hooks:pre-commit:verify": {
      "dependencies": ["check:test", "check:types", "check:changelog", "publish:check-dirty"]
    },
    "ci": { "dependencies": ["check", "publish:check"] },
    "check": {
      "dependencies": ["check:fmt", "check:lint", "check:test", "check:types", "check:changelog"]
    },
    "check:fmt": "deno fmt --check",
    "check:lint": "deno lint",
    "check:test": "deno test --doc --allow-all",
    "check:types": "deno check src test scripts",
    "check:changelog": "deno run --allow-read=deno.json,CHANGELOG.md scripts/changelog.ts --check",
    "fix:fmt": "deno fmt",
    "fix:lint": "deno lint --fix",
    "changelog": "deno run --allow-read=deno.json --allow-run=git-cliff scripts/changelog.ts",
    "release": "deno run --allow-read=deno.json --allow-net=jsr.io --allow-run=git,deno scripts/release.ts",
    "publish:check": "deno publish --dry-run",
    "publish:check-dirty": "deno publish --dry-run --allow-dirty"
  },
  "fmt": {
    "lineWidth": 100
  },
  "exclude": ["test/data"],
  "publish": {
    "include": ["src", "CHANGELOG.md", "README.md", "LICENSE", "deno.json"]
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "@jeiea/mock-fetch": "jsr:@jeiea/mock-fetch@^0.1.0",
    "@jeiea/userscript-metadata": "jsr:@jeiea/userscript-metadata@^0.2.0",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/semver": "jsr:@std/semver@^1.0.8",
    "@std/testing": "jsr:@std/testing@^1.0.15",
    "@stitches/react": "npm:@stitches/react",
    "fflate": "npm:fflate",
    "lint-staged": "npm:lint-staged@^17.0.5",
    "react-dom": "npm:react-dom",
    "react": "npm:react",
    "library1": "data:,export{}",
    "rolldown": "npm:rolldown@^1.0.0-beta.40",
    "unplugin": "npm:unplugin@^2.3.10"
  },
  "compilerOptions": {
    "lib": ["deno.window", "DOM"],
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true
  }
}
